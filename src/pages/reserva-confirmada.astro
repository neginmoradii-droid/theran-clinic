---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Reserva confirmada — THERAN Clinic">
  <section class="resultado-section">
    <div class="resultado-card">
      <div class="icono">✓</div>
      <p class="eyebrow">Pago completado</p>
      <h1>¡Reserva confirmada!</h1>
      <p class="texto">Hemos recibido tu pago de <strong>10&nbsp;€</strong>. En breve recibirás un correo con los detalles de tu cita. ¡Hasta pronto!</p>
      <a href="/" class="btn-volver">Volver al inicio</a>
    </div>
  </section>
</Layout>

<style>
  .resultado-section {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 120px 24px 60px;
    background: #f8f6f3;
  }
  .resultado-card {
    background: #fff;
    border-radius: 2px;
    box-shadow: 0 2px 40px rgba(0,0,0,0.07);
    padding: 52px 48px;
    max-width: 440px;
    width: 100%;
    text-align: center;
  }
  .icono {
    width: 64px; height: 64px;
    border-radius: 50%;
    background: #e8f5e9;
    color: #2e7d32;
    font-size: 28px;
    display: flex; align-items: center; justify-content: center;
    margin: 0 auto 24px;
  }
  .eyebrow {
    font-family: 'Jost', sans-serif;
    font-size: 11px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #999;
    margin: 0 0 12px;
  }
  h1 {
    font-family: 'Cormorant Garamond', serif;
    font-size: 28px;
    font-weight: 400;
    color: #1a1a1a;
    margin: 0 0 20px;
  }
  .texto {
    font-family: 'Jost', sans-serif;
    font-size: 14px;
    color: #777;
    line-height: 1.8;
    margin: 0 0 32px;
  }
  .btn-volver {
    display: inline-block;
    padding: 13px 32px;
    background: #1a1a1a;
    color: #fff;
    font-family: 'Jost', sans-serif;
    font-size: 12px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 1px;
    transition: background 0.2s;
  }
  .btn-volver:hover { background: #333; }
</style>
